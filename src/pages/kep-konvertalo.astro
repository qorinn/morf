---
import ImageWorkspace from "@/components/workspace/ImageWorkspace";
import SiteFooter from "@/components/layout/SiteFooter.astro";
import SiteHeader from "@/components/layout/SiteHeader.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import PrivacySection from "@/components/sections/PrivacySection.astro";
import { Badge } from "@/components/ui/badge";
import ToolHero from "@/components/sections/ToolHero.astro";
import MainLayout from "@/layouts/main.astro";

const privacyItems = [
  "A kép dekódolása, az EXIF-orientáció alkalmazása, az átméretezés és a kiválasztott formátumba kódolás külön Web Workerben fut a saját böngésződben.",
  "A preview-khoz ideiglenes Blob URL-ek készülnek. Ezeket Morf felszabadítja, amikor eltávolítod a fájlt vagy elhagyod az oldalt.",
  "Nincs regisztráció, napi limit, fájlhoz kapcsolt analitika vagy szerveres képfeltöltés az aktív munkafelületen.",
];

const faqItems = [
  {
    question: "Valóban nem töltődnek fel a képek?",
    answer:
      "Igen. A kiválasztott fájlok feldolgozása a böngésződben történik, Morf szerverére nem kerülnek fel.",
  },
  {
    question: "Milyen formátumok között konvertálhatok?",
    answer:
      "JPG, PNG, WebP, AVIF és HEIC/HEIF állóképeket adhatsz hozzá, a kimenet pedig JPG, PNG, WebP vagy AVIF lehet. A Morf a fájl tényleges tartalmát is ellenőrzi, nem csak a kiterjesztését.",
  },
  {
    question: "Mi történik az átlátszó háttérrel JPG konvertáláskor?",
    answer:
      "A JPG nem támogatja az átlátszóságot, ezért az átlátszó képpontok hátteret kapnak. Ha meg szeretnéd tartani az átlátszóságot, válassz PNG, WebP vagy AVIF kimenetet.",
  },
  {
    question: "Mekkora képet konvertálhatok?",
    answer:
      "Nincs napi limit vagy fájlszámláló, de a biztonságos fájlméretet az eszközöd memóriája és teljesítménye korlátozza. Mobilon Morf konzervatívabb határt használ.",
  },
  {
    question: "Az animált képek megőrzik az animációt?",
    answer:
      "Nem. Az első verzió állóképekhez készült, animációmegőrzést nem ígér.",
  },
];
---

<MainLayout
  title="Képkonvertáló – JPG, PNG, WebP, AVIF és HEIC | Morf"
  description="Rendezd konfigurációs csoportokba tetszőleges számú JPG, PNG, WebP, AVIF vagy HEIC képedet, majd konvertáld őket egyetlen futtatással."
>
  <SiteHeader
    active="converter"
    actionHref="#workspace"
    actionLabel="Konvertáló megnyitása"
    actionShortLabel="Megnyitás"
  />

  <main>
    <ToolHero
      badge="JPG · PNG · WebP · AVIF · HEIC"
      title="Konvertálj több képet egyszerre."
      description="Rendezd a képeket közös vagy külön konfigurációs csoportokba. A Morf egyetlen futtatással, közvetlenül a böngésződben alakítja át őket."
      primaryAction={{ href: "#workspace", label: "Képek konvertálása" }}
      secondaryAction={{ href: "#hogyan-mukodik", label: "Hogyan működik?" }}
      features={[
        {
          title: "Egyszerre több fájl",
          description:
            "A képek közös vagy külön csoportok beállításait használhatják, és egyenként kihagyhatók a konvertálásból.",
        },
        {
          title: "Méret és minőség egy helyen",
          description:
            "Konvertálás közben aránytartó átméretezést és tömörítést is beállíthatsz.",
        },
        {
          title: "Rugalmas mentés",
          description:
            "Mentsd az eredményeket egyenként, kiválasztott helyre vagy egyetlen ZIP-fájlba.",
        },
      ]}
    />

    <ImageWorkspace client:load />

    <section
      id="hogyan-mukodik"
      class="mx-auto flex w-full max-w-7xl flex-col gap-10 px-4 py-20 sm:px-6 lg:px-8"
    >
      <div class="max-w-2xl">
        <p class="text-muted-foreground text-sm font-medium">Három lépés</p>
        <h2
          class="font-heading mt-2 text-3xl font-medium tracking-tight sm:text-4xl"
        >
          Három lépés a kész képekig
        </h2>
      </div>
      <ol class="grid gap-8 md:grid-cols-3">
        <li class="flex flex-col gap-3">
          <Badge variant="outline">01</Badge>
          <h3 class="font-heading text-xl font-medium">Add hozzá a képeket</h3>
          <p class="text-muted-foreground">
            Húzd be vagy válaszd ki a JPG, PNG, WebP, AVIF és HEIC állóképeket.
            Alapból minden kép egy közös csoportba kerül, kijelölés nélkül.
          </p>
        </li>
        <li class="flex flex-col gap-3">
          <Badge variant="outline">02</Badge>
          <h3 class="font-heading text-xl font-medium">
            Állítsd be a kimenetet
          </h3>
          <p class="text-muted-foreground">
            Hozz létre konfigurációs csoportokat, állítsd be a formátumot,
            méretet és minőséget, majd rendeld hozzájuk a képeket.
          </p>
        </li>
        <li class="flex flex-col gap-3">
          <Badge variant="outline">03</Badge>
          <h3 class="font-heading text-xl font-medium">Konvertálj és ments</h3>
          <p class="text-muted-foreground">
            Egyetlen indítással minden bevont kép a saját csoportjának
            beállításaival készül el, majd egyenként vagy ZIP-ben menthető.
          </p>
        </li>
      </ol>
    </section>

    <PrivacySection
      title="A konvertálás a böngésződben történik"
      description="A kiválasztott képek nem kerülnek a Morf szerverére: a beolvasás, az átméretezés és az új fájl elkészítése is a saját eszközödön fut."
      items={privacyItems}
    />

    <FaqSection
      title="Képkonvertálás, röviden"
      description="Válaszok a támogatott formátumokról, az átlátszóságról, a fájlméretről és a helyi feldolgozásról."
      items={faqItems}
    />
  </main>

  <SiteFooter />
</MainLayout>
