---
import { Badge } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";

interface Feature {
  title: string;
  description: string;
}

interface Action {
  href: string;
  label: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  primaryAction: Action;
  secondaryAction?: Action;
  features: Feature[];
}

const { badge, title, description, primaryAction, secondaryAction, features } =
  Astro.props;
---

<section
  class="mx-auto grid w-full max-w-7xl gap-10 px-4 pt-16 pb-14 sm:px-6 sm:pt-24 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.65fr)] lg:items-end lg:px-8 lg:pt-32 lg:pb-20"
>
  <div class="flex flex-col items-start gap-6">
    <Badge variant="secondary">{badge}</Badge>
    <div class="flex flex-col gap-4">
      <h1
        class="font-heading max-w-4xl text-5xl font-medium tracking-tight text-balance sm:text-6xl lg:text-7xl"
      >
        {title}
      </h1>
      <p
        class="text-muted-foreground max-w-2xl text-lg leading-relaxed sm:text-xl"
      >
        {description}
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href={primaryAction.href} class={buttonVariants({ size: "lg" })}>
        {primaryAction.label}
      </a>
      {
        secondaryAction && (
          <a
            href={secondaryAction.href}
            class={buttonVariants({ variant: "ghost", size: "lg" })}
          >
            {secondaryAction.label}
          </a>
        )
      }
    </div>
  </div>

  <ul class="flex flex-col gap-5 text-sm">
    {
      features.map((feature) => (
        <li>
          <p class="font-medium">{feature.title}</p>
          <p class="text-muted-foreground mt-1">{feature.description}</p>
        </li>
      ))
    }
  </ul>
</section>
